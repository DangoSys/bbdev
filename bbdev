def forward_iii_output(pipe, active_event: threading.Event, quiet: bool = False):
    """Forward task output to stdout. In quiet mode, suppress engine infrastructure logs."""
    for line in iter(pipe.readline, ""):
        if not active_event.is_set():
            continue
        if quiet:
            # Suppress engine infrastructure INFO/WARN; pass everything else
            if any(mod in line for mod in _ENGINE_INFRA_MODULES):
                continue
            sys.stdout.write(line)
            sys.stdout.flush()
        else:
            sys.stdout.write(line)
            sys.stdout.flush()
    pipe.close()


def read_state_file(path: str):
    """Read JSON from an iii state file (JSON + binary padding). Returns parsed dict or None."""
    try:
        with open(path, "r", errors="ignore") as f:
            raw = f.read()
        state_data, _ = json.JSONDecoder().raw_decode(raw)
        return state_data
    except (FileNotFoundError, json.JSONDecodeError, ValueError):
        return None


def run_server_mode(args, cmd_info):
    """Handle --server mode: interact with an already-running (or new) iii server."""
    command = cmd_info["command"]

    if command == "start":
        print(f"Starting dev server on port {args.port}")
        if args.port:
            worker_port, worker_sock = reserve_port(start_port=WORKER_PORT_START, end_port=WORKER_PORT_END)
            worker_sock.close()
            config_path = make_iii_config(args.port, worker_port)
            worker_url = f"ws://{HOST}:{worker_port}"
            print(f"Using worker port {worker_port}")
        else:
            config_path = os.path.join(workflow_dir, "config.yaml")
            worker_url = f"ws://{HOST}:49134"
        proc = None
        try:
            env = {**os.environ, "PYTHONDONTWRITEBYTECODE": "1"}
            if worker_url:
                env["III_URL"] = worker_url
            proc = subprocess.Popen(
                ["iii", "-c", config_path],
                cwd=workflow_dir,
                env=env,
                start_new_session=True,
            )
            rc = proc.wait()
            if rc != 0:
                sys.exit(rc)
        finally:
            if proc:
                terminate_group(proc)
            stop_workspace_servers(workflow_dir, worker_url=worker_url)
            if args.port:
                cleanup_config(config_path)

    elif command == "stop":
        if cmd_info["operation"] == "all":
            count = stop_workspace_servers(workflow_dir)
            print(f"Stopped {count} process(es) for this workspace")
        else:
            count = stop_workspace_servers(workflow_dir, port=args.port)
            if args.port:
                print(f"Stopped {count} process(es) on port {args.port}")
            else:
                print(f"Stopped {count} process(es) for this workspace")

    elif command in WORKFLOW_COMMANDS:
        api_path = f"/{command.replace('-', '/')}/{cmd_info['operation']}"
        resp = requests.post(
            f"http://{HOST}:{args.port}{api_path}",
            json=cmd_info["args"],
            timeout=30,
            proxies=NO_PROXY,
        )
        print(resp.text)

    else:
        print(f"Unknown command: {command}")
        print(f"Available commands: {', '.join(ALL_COMMANDS)}")
        sys.exit(1)


def _submit_and_poll(port: int, api_path: str, cmd_info: dict):
    """Submit a task to iii and poll for its result. Returns exit code (0=ok, 1=fail)."""
    base_url = f"http://{HOST}:{port}"
    print(f"Executing {cmd_info['command']} {cmd_info['operation']}...")
    try:
        submit_resp = requests.post(
            f"{base_url}{api_path}",
            json=cmd_info["args"],
            timeout=30,
            proxies=NO_PROXY,
        )
        submit_data = submit_resp.json()
    except Exception as e:
        print(f"Error: Failed to submit task: {e}")
        return 1

    if submit_resp.status_code >= 400:
        print(f"Error: {submit_data}")
        return 1

    trace_id = submit_data.get("trace_id", "")
    if not trace_id:
        print(f"Error: No trace_id in response: {submit_data}")
        return 1

    # Poll for result
    state_file = os.path.join(workflow_dir, "data", "state_store.db", f"{trace_id}.bin")
    poll_timeout = 24 * 60 * 60  # 24 hours max
    task_result = None
    legacy_processing_count = 0
    for _ in range(poll_timeout // 2):
        state_data = read_state_file(state_file)
        if state_data:
            if "success" in state_data:
                task_result = state_data["success"].get("body", state_data["success"])
                break
            elif "failure" in state_data:
                task_result = state_data["failure"].get("body", state_data["failure"])
                break
            elif state_data.get("processing") is True:
                legacy_processing_count += 1
                if legacy_processing_count >= 30:
                    print("Error: Task is stuck in legacy processing state; worker did not advance the queue")
                    return 1
            else:
                legacy_processing_count = 0
        time.sleep(2)
    else:
        print("Error: Task polling timed out after 24 hours")
        return 1

    print(f"\nTask completed on http://{HOST}:{port}")
    if task_result and not task_result.get("success", False):
        print("Error: Task failed")
        return 1
    return 0


def run_script_mode(args, cmd_info):
    """Handle script mode: start iii, run one task, then shut down."""
    command = cmd_info["command"]

    if command == "start":
        print(f"'{command}' does nothing in script mode")
        return
    if command == "stop":
        count = stop_workspace_servers(workflow_dir, port=args.port)
        if args.port:
            print(f"Stopped {count} process(es) on port {args.port}")
        else:
            print(f"Stopped {count} process(es) for this workspace")
        return

    if command not in WORKFLOW_COMMANDS:
        print(f"Unknown command: {command}")
        print(f"Available commands: {', '.join(ALL_COMMANDS)}")
        sys.exit(1)

    api_path = f"/{command.replace('-', '/')}/{cmd_info['operation']}"

    # Reserve both ports atomically to prevent TOCTOU races with concurrent bbdev instances.
    # Sockets stay bound until the engine has taken over (HTTP is up), then are released.
    if args.port:
        available_port = args.port
        http_sock = None
    else:
        available_port, http_sock = reserve_port(
            start_port=HTTP_PORT_START,
            end_port=HTTP_PORT_END,
            preferred_port=user_preferred_port(HTTP_PORT_START, HTTP_PORT_END),
        )
    worker_port, worker_sock = reserve_port(
        start_port=WORKER_PORT_START,
        end_port=WORKER_PORT_END,
        preferred_port=user_preferred_port(WORKER_PORT_START, WORKER_PORT_END),
    )
    print(f"Starting server on port {available_port}...")

    # Clean stale state files from previous runs
    state_dir = os.path.join(workflow_dir, "data", "state_store.db")
    if os.path.isdir(state_dir):
        for f in os.listdir(state_dir):
            if f.endswith(".bin"):
                try:
                    os.unlink(os.path.join(state_dir, f))
                except OSError:
                    pass
    clean_python_caches(workflow_dir)

    config_path = make_iii_config(
        available_port,
        worker_port,
        quiet=True,
        exec_module=False,
    )
    iii_output_active = threading.Event()
    iii_output_active.set()

    # Release reserved sockets just before engine starts so it can bind the same ports.
    if http_sock:
        http_sock.close()
    worker_sock.close()

    # Set III_URL so motia SDK connects to the correct worker port
    iii_env = {
        **os.environ,
        "III_URL": f"ws://{HOST}:{worker_port}",
        "PYTHONDONTWRITEBYTECODE": "1",
        "BUCKYBALL_ROOT": os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
    }
    proc = subprocess.Popen(
        ["iii", "-c", config_path],
        cwd=workflow_dir,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        env=iii_env,
        start_new_session=True,
    )
    worker_proc = None

    output_thread = threading.Thread(
        target=forward_iii_output, args=(proc.stdout, iii_output_active, True), daemon=True
    )
    output_thread.start()

    try:
        base_url = f"http://{HOST}:{available_port}"

        # Phase 1: wait for iii engine HTTP
        if not wait_for_http(
            f"{base_url}/",
            check_fn=lambda r: True,
            timeout=30,
            error_msg="Server failed to start within 30 seconds",
        ):
            sys.exit(1)

        worker_proc = subprocess.Popen(
            [".venv/bin/motia", "dev", "--dir", "steps"],
            cwd=workflow_dir,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            env=iii_env,
            start_new_session=True,
        )
        worker_output_thread = threading.Thread(
            target=forward_iii_output,
            args=(worker_proc.stdout, iii_output_active, True),
            daemon=True,
        )
        worker_output_thread.start()

        # Phase 2: wait for route registration
        if not wait_for_http(
            f"{base_url}{api_path}",
            check_fn=lambda r: r.status_code != 404,
            timeout=120,
            error_msg="Routes failed to register within timeout",
        ):
            sys.exit(1)
        time.sleep(2)

        print(f"Server is ready on port {available_port}")
        rc = _submit_and_poll(available_port, api_path, cmd_info)
        if rc != 0:
            sys.exit(rc)

    finally:
        # Cleanup: stop iii, its process group, and any workspace worker it spawned.
        iii_output_active.clear()
        time.sleep(0.5)
        if worker_proc:
            terminate_group(worker_proc)
        terminate_group(proc)
        stop_workspace_servers(workflow_dir, worker_url=iii_env["III_URL"])
        cleanup_config(config_path)


if __name__ == "__main__":
    args = parse_args(sys.argv[1:])
    cmd_info = extract_command_info(args)

    if args.server:
        run_server_mode(args, cmd_info)
    else:
        run_script_mode(args, cmd_info)
