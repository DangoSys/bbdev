workflow_dir = os.path.dirname(os.path.abspath(__file__)) + "/api"


def make_iii_config(port: int) -> str:
    """Create a temporary config.yaml with the specified port, return the path."""
    base_config = os.path.join(workflow_dir, "config.yaml")
    with open(base_config, "r") as f:
        content = f.read()
    # Replace the RestApiModule port
    content = re.sub(r"(port:\s*)\d+", rf"\g<1>{port}", content, count=1)
    tmp = tempfile.NamedTemporaryFile(
        mode="w", suffix=".yaml", prefix="iii-config-", dir=workflow_dir, delete=False
    )
    tmp.write(content)
    tmp.close()
    return tmp.name


